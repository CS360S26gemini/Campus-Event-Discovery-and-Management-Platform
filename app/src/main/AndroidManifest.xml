<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- Required for Firebase Storage putFile(Uri) on Android 12 and below -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Required for Firebase Storage putFile(Uri) on Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:name=".CampusEventDiscoveryApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CampusEventDiscovery">

        <activity
            android:name="com.example.CampusEventDiscovery.MaintenanceActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.OrganizerProposalDetailActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.ui.profile.NotificationCenterActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.ui.profile.MemoriesActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.ui.organizer.WhoIsComingActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.ui.organizer.OrganizerEventDetailActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.SignUpActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.SignInActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.WelcomeActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.organizer.ManageEventsActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.profile.AccountSettingsActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.organizer.CreateEventActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.EventApprovalActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.CheckoutActivity"
            android:exported="false" />
        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.EventFeedbackActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.BuyTicketActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.EventDetailActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.event.TicketActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.ui.organizer.ScannerActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.MainActivity"
            android:exported="false" />

        <activity
            android:name="com.example.CampusEventDiscovery.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CampusEventDiscovery.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
