<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSettings"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/account_settings"
        app:titleTextColor="@color/colorOnBackground" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarSettings">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:id="@+id/settingsTabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProfileTab"
                    style="@style/AppSecondaryButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/profile_details_tab" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmailTab"
                    style="@style/AppSecondaryButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:layout_weight="1"
                    android:text="@string/change_email_tab" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPasswordTab"
                    style="@style/AppSecondaryButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/change_password_tab" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profileSettingsPage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_name_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/full_name_label"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/primary_campus"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <AutoCompleteTextView
                    android:id="@+id/etUniversity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/campus_hint"
                    android:inputType="none"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Location"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="e.g. Lahore"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/interests_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <MultiAutoCompleteTextView
                    android:id="@+id/etInterests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/interests_dropdown_hint"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/emailSettingsPage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/email_address_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/email_address_label"
                    android:inputType="textEmailAddress"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/current_password_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etEmailCurrentPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/current_password_hint"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/passwordSettingsPage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_password_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etPasswordCurrentPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/current_password_hint"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/new_password_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/new_password_hint"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/confirm_new_password_label"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_rounded"
                    android:hint="@string/confirm_new_password_hint"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:textColor="@color/colorOnBackground"
                    android:textColorHint="@color/colorSecondary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                style="@style/AppButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:padding="14dp"
                android:text="@string/save_profile" />

            <ProgressBar
                android:id="@+id/progressBarSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
