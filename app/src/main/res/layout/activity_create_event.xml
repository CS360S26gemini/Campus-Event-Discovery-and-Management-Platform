<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarCreateEvent"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorSurface"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/colorOnBackground"
            app:title="@string/create_event_header"
            app:titleTextColor="@color/colorOnBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="@string/event_title"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="@string/event_title_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="Event Image"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivEventThumbnail"
                android:layout_width="80dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_event"
                android:background="@color/colorSurface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectImage"
                style="@style/AppSecondaryButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/select_event_image" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/event_date"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/event_date_hint"
                android:textColor="@color/colorSecondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickDate"
                style="@style/AppSecondaryButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pick_date" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/event_category"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <AutoCompleteTextView
            android:id="@+id/actvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="@string/event_category_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/venue"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etVenue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="@string/venue_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/description"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="top|start"
            android:hint="@string/description_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/capacity_hint"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="500"
            android:inputType="number"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="Ticket Price (PKR) — leave 0 for free"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etTicketPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="0"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/tags_label"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="@string/tags_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/sponsors_label"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etSponsors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="@string/sponsors_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/food_stalls_label"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etFoodStalls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="@string/food_stalls_hint"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/trailer_url_hint"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etTrailerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_rounded"
            android:hint="https://youtube.com/..."
            android:inputType="textUri"
            android:padding="14dp"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/colorSecondary" />

        <ProgressBar
            android:id="@+id/progressBarCreateEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitEvent"
            style="@style/AppButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            android:padding="14dp"
            android:text="@string/submit" />
    </LinearLayout>

</ScrollView>