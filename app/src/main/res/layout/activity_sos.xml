<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSos"
        style="@style/AppToolbarStyle"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationContentDescription="@string/back"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/sos" />

    <TextView
        android:id="@+id/tvSosHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sos_alert_sent_title"
        android:textColor="@color/colorError"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        app:layout_constraintTop_toBottomOf="@id/toolbarSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <TextView
        android:id="@+id/tvSosMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sos_alert_sent_message"
        android:textColor="?attr/colorOnSurface"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_lg"
        app:layout_constraintTop_toBottomOf="@id/tvSosHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvMapsUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorPrimary"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:gravity="center"
        android:padding="12dp"
        android:layout_marginTop="@dimen/spacing_md"
        android:autoLink="web"
        app:layout_constraintTop_toBottomOf="@id/tvSosMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSosClose"
        style="@style/AppButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/close"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
