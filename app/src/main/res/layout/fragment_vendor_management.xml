<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/tvVendorHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vendor_management"
                android:textColor="@color/colorOnBackground"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVendorSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/vendor_management_subtitle"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToVendorEvents"
                style="@style/AppOutlinedButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/back"
                android:visibility="gone"
                app:icon="@drawable/ic_back"
                app:iconTint="?attr/colorPrimary" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVendorToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorOutlineVariant"
            app:strokeWidth="1dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleVendorStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                app:checkedButton="@+id/btnVendorApproved"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVendorApproved"
                    style="@style/AppAdminToggleButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/approved_vendors"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVendorPending"
                    style="@style/AppAdminToggleButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/pending_vendors"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVendorRejected"
                    style="@style/AppAdminToggleButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/rejected_vendors"
                    app:cornerRadius="8dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvVendorEventPrompt"
            style="@style/AppSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/select_event_for_vendors" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVendorEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingTop="@dimen/spacing_xs" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVendorProposals"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/bottom_nav_safe_padding" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVendorEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:drawableTop="@drawable/ic_person"
        android:drawablePadding="@dimen/spacing_md"
        android:gravity="center"
        android:text="@string/no_vendor_requests"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="@color/colorOnSurface"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressVendor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddVendor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        android:contentDescription="@string/add_vendor"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary" />
</FrameLayout>
