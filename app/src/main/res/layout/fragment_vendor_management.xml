<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarVendorManagement"
            style="@style/AppToolbarStyle"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorBackground"
            android:paddingHorizontal="@dimen/spacing_md"
            app:title="@string/vendor_management" />

        <TextView
            android:id="@+id/tvVendorSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/vendor_management_subtitle"
            android:textColor="@color/colorOnSurfaceVariant"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVendorToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVendorApproved"
                    style="@style/AppSegmentToggleButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/approved_vendors" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVendorPending"
                    style="@style/AppSegmentToggleButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/pending_vendors" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVendorRejected"
                    style="@style/AppSegmentToggleButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/rejected_vendors" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvVendorEventPrompt"
            style="@style/AppSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/select_event_for_vendors" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVendorEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingTop="@dimen/spacing_xs" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVendorProposals"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/bottom_nav_safe_padding" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVendorEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:drawableTop="@drawable/ic_person"
        android:drawablePadding="@dimen/spacing_md"
        android:gravity="center"
        android:text="@string/no_vendor_requests"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="@color/colorOnSurface"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressVendor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddVendor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        android:contentDescription="@string/add_vendor"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary" />
</FrameLayout>
