<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:foreground="?attr/selectableItemBackground"
    android:padding="2dp">

    <ImageView
        android:id="@+id/ivMemoryAlbumPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:background="@drawable/bg_placeholder_image"
        android:contentDescription="@string/memory_album_title"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/viewMemoryPhotoSelectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/ivMemoryPhotoSelectionCheck"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:background="@drawable/bg_chip_selected"
        android:contentDescription="@string/memory_selected_photos"
        android:padding="4dp"
        android:src="@drawable/ic_verified"
        android:visibility="gone" />
</FrameLayout>
