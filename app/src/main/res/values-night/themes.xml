<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.CampusEventDiscovery" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnBackground</item>

        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnBackground</item>
        <item name="colorOnBackground">@color/colorOnBackground</item>

        <item name="android:statusBarColor">@color/colorSurface</item>
        <item name="android:navigationBarColor">@color/colorSurface</item>
        <item name="android:windowBackground">@color/colorBackground</item>

        <item name="android:textColor">@color/colorOnBackground</item>
        <item name="android:editTextColor">@color/colorOnBackground</item>

        <item name="materialCardViewFilledStyle">@style/AppMaterialCardView</item>
        <item name="buttonStyle">@style/AppButtonStyle</item>
        <item name="imageButtonStyle">@style/AppImageButtonStyle</item>
        <item name="android:windowAnimationStyle">@style/AppWindowAnimation</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="AppMaterialCardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="strokeColor">@color/transparent</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <style name="AppButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/colorPrimaryRipple</item>
    </style>

    <style name="AppSecondaryButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/colorSurfaceRaised</item>
        <item name="android:textColor">@color/colorOnBackground</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/colorPrimaryRipple</item>
    </style>

    <style name="AppDangerButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/colorSOS</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/colorSosRipple</item>
    </style>

    <style name="AppOutlinedButtonStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/colorOnBackground</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/colorPrimaryRipple</item>
    </style>

    <style name="AppCompactButtonStyle" parent="@style/AppSecondaryButtonStyle">
        <item name="android:minWidth">40dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="AppImageButtonStyle" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="AppWindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/screen_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/screen_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/screen_pop_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/screen_pop_exit</item>
        <item name="android:taskOpenEnterAnimation">@anim/screen_enter</item>
        <item name="android:taskOpenExitAnimation">@anim/screen_exit</item>
        <item name="android:taskCloseEnterAnimation">@anim/screen_pop_enter</item>
        <item name="android:taskCloseExitAnimation">@anim/screen_pop_exit</item>
        <item name="android:taskToFrontEnterAnimation">@anim/screen_enter</item>
        <item name="android:taskToFrontExitAnimation">@anim/screen_exit</item>
        <item name="android:taskToBackEnterAnimation">@anim/screen_pop_enter</item>
        <item name="android:taskToBackExitAnimation">@anim/screen_pop_exit</item>
    </style>

</resources>
